# ============================================================
# Tholth Way | ثُلث — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=tholth
POSTGRES_PASSWORD=tholth_secure_2024
POSTGRES_DB=tholthway
POSTGRES_PORT=5432

# ── pgAdmin 4 ────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@tholthway.com
PGADMIN_DEFAULT_PASSWORD=admin1234
PGADMIN_PORT=5050

# ── RustFS (S3-compatible object storage) ────────────────────
RUSTFS_ACCESS_KEY=tholth_admin
RUSTFS_SECRET_KEY=tholth_rustfs_2024
RUSTFS_PORT=9000
RUSTFS_CONSOLE_PORT=9001
RUSTFS_ENDPOINT=http://rustfs:9000
RUSTFS_BUCKET=meal-images

# ── Backend API ──────────────────────────────────────────────
API_PORT=4000
DATABASE_URL=postgresql://tholth:tholth_secure_2024@db:5432/tholthway?schema=public
NODE_ENV=production

# ── Frontend ─────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:4000
FRONTEND_PORT=3000
